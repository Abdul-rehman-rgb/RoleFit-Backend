{
  "version": 2,
  "installCommand": "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true npm install --omit=dev",
  "builds": [
    { "src": "api/health.js", "use": "@vercel/node" },
    { "src": "api/auth.js", "use": "@vercel/node", "config": { "maxDuration": 30, "memory": 512 } },
    { "src": "api/interview.js", "use": "@vercel/node", "config": { "maxDuration": 60, "memory": 1024 } },
    { "src": "api/upload.js", "use": "@vercel/node", "config": { "maxDuration": 30, "memory": 512 } },
    { "src": "api/analyze.js", "use": "@vercel/node", "config": { "maxDuration": 60, "memory": 512 } }
  ],
  "routes": [
    { "src": "/api/health", "dest": "api/health.js" },
    { "src": "/api/auth", "dest": "api/auth.js" },
    { "src": "/api/auth/(.*)", "dest": "api/auth.js" },
    { "src": "/api/interview", "dest": "api/interview.js" },
    { "src": "/api/interview/(.*)", "dest": "api/interview.js" },
    { "src": "/api/upload", "dest": "api/upload.js" },
    { "src": "/api/upload/(.*)", "dest": "api/upload.js" },
    { "src": "/api/analyze", "dest": "api/analyze.js" },
    { "src": "/api/analyze/(.*)", "dest": "api/analyze.js" }
  ]
}
