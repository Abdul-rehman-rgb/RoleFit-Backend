{
  "version": 2,
  "installCommand": "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true npm install --omit=dev",
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/health.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/health.js": {
      "memory": 128
    }
  }
}
